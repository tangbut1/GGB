# ==========================================
# MarketPulse 环境变量配置
# 复制此文件为 .env 并填入你的 API Key
# ==========================================

# ==========================================
# 1. 全局一键自定义模型（可选）
#    默认使用 DeepSeek: deepseek-v4-flash
#    如果想全局替换成其他兼容 OpenAI 协议的模型（例如 Kimi/Qwen/GPT-4o），解开注释并配置：
# ==========================================
# MP_GLOBAL_BASE_URL=https://api.openai.com/v1
# MP_GLOBAL_MODEL=gpt-4o

# ==========================================
# 2. 针对单个 Agent 覆盖（可选，优先级高于全局）
#    格式：MP_{AGENT_NAME}_MODEL 或 MP_{AGENT_NAME}_BASE_URL
# ==========================================
# MP_SENTIMENT_AGENT_MODEL=deepseek-v4-pro
# MP_TREND_AGENT_BASE_URL=https://api.openai.com/v1

# ==========================================
# 3. 核心凭证配置：API Key
# ==========================================
# CollectAgent - 数据采集与清洗
MP_COLLECT_AGENT_API_KEY=sk-your-key-here

# SentimentAgent - 情感分析
MP_SENTIMENT_AGENT_API_KEY=sk-your-key-here

# TrendAgent - 趋势预测
MP_TREND_AGENT_API_KEY=sk-your-key-here

# ReportAgent - 报告生成
MP_REPORT_AGENT_API_KEY=sk-your-key-here

# Forum Host - 论坛主持人
MP_FORUM_HOST_API_KEY=sk-your-key-here

# ==========================================
# 4. 备用搜索 API（可选）
# ==========================================
# NewsAPI 备用新闻源 (https://newsapi.org/register)
# NEWSAPI_KEY=your_news_api_key

# ==========================================
# 5. Flask 安全密钥
# ==========================================
SECRET_KEY=change-me-in-production
